# Copy to .env for Nest on the HOST with only Postgres via Compose:
NODE_ENV=development
PORT=3050
DB_HOST=localhost
DB_PORT=5460
DB_NAME=ledger
DB_USER=ledger
DB_PASSWORD=ledger

# When using `docker compose up` with the bundled API service,
# Compose sets DB_HOST=postgres internally. Optional overrides only for Compose:
# API_PORT=3050
# HOST_DB_PORT=5460
# POSTGRES_DB=ledger
# POSTGRES_USER=ledger
# POSTGRES_PASSWORD=ledger
